<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vue Tree (Liste) -->
        <record id="view_workflow_type_tree" model="ir.ui.view">
            <field name="name">workflow.type.tree</field>
            <field name="model">workflow.type</field>
            <field name="arch" type="xml">
                <tree string="Types de Workflow">
                    <field name="name"/>
                    <field name="category"/>
                    <field name="code"/>
                    <field name="description"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <!-- Vue Form (Formulaire) -->
        <record id="view_workflow_type_form" model="ir.ui.view">
            <field name="name">workflow.type.form</field>
            <field name="model">workflow.type</field>
            <field name="arch" type="xml">
                <form string="Type de Workflow">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <widget name="web_ribbon" title="Archivé" bg_color="bg-danger" invisible="active"/>
                        </div>
                        <group>
                            <group>
                                <field name="name" placeholder="Ex: Crédit Bancaire, Congé, Achat..."/>
                                <field name="category"/>
                                <field name="code" readonly="1"/>
                            </group>
                            <group>
                                <field name="active"/>
                            </group>
                        </group>
                        <div class="alert alert-info" style="margin: 0 16px 16px 16px; padding: 10px 14px; border-radius: 8px; font-size: 13px;">
                            <strong>ℹ️ Catégorie :</strong> Détermine dans quel tableau de bord ce type apparaît.
                            Choisissez <b>💳 Crédit Bancaire</b> pour le tableau de bord Crédit,
                            <b>📬 Courrier Entrant</b> pour le tableau de bord Courrier,
                            ou <b>📋 Autre</b> pour un type indépendant.
                            <br/>
                            <strong>Code technique :</strong> généré automatiquement depuis le nom (référence interne, non modifiable).
                        </div>
                        <group>
                            <field name="description" placeholder="Description du type de workflow..."/>
                        </group>

                        <!-- Onglet : Champs personnalisés du formulaire -->
                        <notebook>
                            <page string="Champs du formulaire" name="custom_fields">
                                <div class="alert alert-info" style="margin: 0 0 12px 0; padding: 10px 14px; border-radius: 8px; font-size: 13px;">
                                    <strong>ℹ️ Template de formulaire :</strong>
                                    Définissez ici les champs supplémentaires que l'utilisateur devra remplir lors de la création d'une demande de ce type.
                                    Ces champs apparaîtront automatiquement dans le formulaire de création.
                                </div>
                                <field name="custom_field_ids" nolabel="1">
                                    <tree string="Champs du formulaire" editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name" string="Nom du champ"
                                               placeholder="Ex : Garantie, Durée, Objet..."/>
                                        <field name="field_type"/>
                                        <field name="required"/>
                                        <field name="placeholder" string="Texte indicatif"
                                               optional="show"
                                               placeholder="Texte d'aide dans le champ..."/>
                                        <field name="selection_options"
                                               optional="show"
                                               invisible="field_type != 'selection'"
                                               placeholder="Option 1&#10;Option 2&#10;Option 3"/>
                                        <field name="active" optional="show"/>
                                    </tree>
                                    <form string="Champ personnalisé">
                                        <group>
                                            <group>
                                                <field name="name"/>
                                                <field name="field_type"/>
                                                <field name="sequence"/>
                                            </group>
                                            <group>
                                                <field name="required"/>
                                                <field name="active"/>
                                                <field name="placeholder"/>
                                            </group>
                                        </group>
                                        <group string="Options de sélection"
                                               invisible="field_type != 'selection'">
                                            <field name="selection_options" nolabel="1"
                                                   placeholder="Saisissez une option par ligne :&#10;Option A&#10;Option B&#10;Option C"/>
                                        </group>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" groups="base.group_user"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Vue Recherche -->
        <record id="view_workflow_type_search" model="ir.ui.view">
            <field name="name">workflow.type.search</field>
            <field name="model">workflow.type</field>
            <field name="arch" type="xml">
                <search string="Rechercher Types de Workflow">
                    <field name="name" string="Nom"/>
                    <field name="code" string="Code"/>
                    <filter string="Actifs" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Archivés" name="inactive" domain="[('active', '=', False)]"/>
                    <group expand="0" string="Regrouper par">
                        <filter string="Code" name="group_by_code" context="{'group_by': 'code'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action de Fenêtre -->
        <record id="action_workflow_type" model="ir.actions.act_window">
            <field name="name">Types de Workflow</field>
            <field name="res_model">workflow.type</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Créer votre premier Type de Workflow
                </p>
                <p>
                    Les types de workflow définissent les catégories de processus métier 
                    (Crédit, Congé, Achat, Mission, etc.) qui nécessitent une validation hiérarchique.
                </p>
            </field>
        </record>

    </data>
</odoo>
